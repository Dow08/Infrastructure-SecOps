[Unit]
Description=Semaphore — Ansible UI (MeetVoice)
Documentation=https://docs.ansible-semaphore.com/
After=network-online.target
Wants=network-online.target
StartLimitIntervalSec=120
StartLimitBurst=5

[Service]
User={{ semaphore_user }}
Group={{ semaphore_group }}
Type=simple
Restart=always
RestartSec=10s
TimeoutStartSec=30
WorkingDirectory={{ semaphore_data_dir }}
ExecStart=/usr/local/bin/semaphore server --config {{ semaphore_config_dir }}/config.json

[Install]
WantedBy=multi-user.target
