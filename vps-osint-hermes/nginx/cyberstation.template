# --- 4. REDIRECTIONS HTTP VERS HTTPS ---
server {
    if ($host = www.{{HUB_DOMAIN}}) {
        return 301 https://$host$request_uri;
    }
    if ($host = {{HUB_DOMAIN}}) {
        return 301 https://$host$request_uri;
    }
    listen 80;
    server_name {{HUB_DOMAIN}} www.{{HUB_DOMAIN}};
    return 404;
}

server {
    if ($host = www.{{HERMES_DOMAIN}}) {
        return 301 https://$host$request_uri;
